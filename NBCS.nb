     RowBox[{"c", "/", "\[Lambda]io"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kpo", " ", "=", " ", 
   RowBox[{
    RowBox[{"nz", "[", 
     RowBox[{"\[Lambda]po", "*", 

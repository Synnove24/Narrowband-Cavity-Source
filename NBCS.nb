Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]po", " ", "=", " ", 
    RowBox[{"520", "*", 
     RowBox[{"10", "^", 
      RowBox[{"-", "9"}]}]}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]so", " ", "=", " ", 
    RowBox[{"780", "*", 
     RowBox[{"10", "^", 
      RowBox[{"-", "9"}]}]}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Lambda]io", " ", "=", " ", 
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"1", "/", "\[Lambda]po"}], " ", "-", 
      RowBox[{"1", "/", "\[Lambda]so"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"c", " ", "=", " ", 

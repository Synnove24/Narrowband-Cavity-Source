     RowBox[{"10", "^", "8"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<The central wavelength for the idler is \>\"", ",", " ", 
    RowBox[{"N", "[", "\[Lambda]io", "]"}], ",", " ", "\"\< nm\>\""}], "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]po", " ", "=", " ", 
   RowBox[{"2", "\[Pi]", " ", 
    RowBox[{"c", "/", "\[Lambda]po"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]so", " ", "=", " ", 
   RowBox[{"2", "\[Pi]", " ", 
    RowBox[{"c", "/", "\[Lambda]so"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]io", " ", "=", " ", 
